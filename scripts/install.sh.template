#!/bin/sh
set -eu

APP_VERSION="@VERSION@"
PYTHON_VERSION="@PYTHON_VERSION@"
UV_VERSION="@UV_VERSION@"
APW_SHA256="@APW_SHA256@"
RELEASE_BASE="https://github.com/Viviana-Luna/agent-project-workflow/releases/download/v${APP_VERSION}"
DRY_RUN=0

if [ "${1:-}" = "--dry-run" ]; then
  DRY_RUN=1
elif [ "$#" -gt 0 ]; then
  printf '错误：未知参数：%s\n' "$1" >&2
  exit 2
fi

fail() {
  printf '错误：%s\n' "$1" >&2
  exit 1
}

shell_quote() {
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

command -v curl >/dev/null 2>&1 || fail "需要 curl 才能下载安装资源"
command -v tar >/dev/null 2>&1 || fail "需要 tar 才能安装私有运行时"

case "$(uname -s)" in
  Darwin|Linux) ;;
  *) fail "首版只支持 macOS 与 Linux" ;;
esac

case "$(uname -m)" in
  x86_64|amd64|arm64|aarch64) ;;
  *) fail "不支持的 CPU 架构：$(uname -m)" ;;
esac

APW_USER_HOME="${APW_INSTALL_HOME:-$HOME}"
if [ -n "${APW_INSTALL_HOME:-}" ]; then
  APW_DATA_DIR="$APW_USER_HOME/.local/share/agent-project-workflow"
  APW_STATE_DIR="$APW_USER_HOME/.local/state/agent-project-workflow"
  APW_CACHE_DIR="$APW_USER_HOME/.cache/agent-project-workflow"
else
  APW_DATA_DIR="${XDG_DATA_HOME:-$APW_USER_HOME/.local/share}/agent-project-workflow"
  APW_STATE_DIR="${XDG_STATE_HOME:-$APW_USER_HOME/.local/state}/agent-project-workflow"
  APW_CACHE_DIR="${XDG_CACHE_HOME:-$APW_USER_HOME/.cache}/agent-project-workflow"
fi
APW_BIN_DIR="$APW_USER_HOME/.local/bin"
APW_RUNTIME_DIR="$APW_DATA_DIR/runtime"
APW_UV_DIR="$APW_RUNTIME_DIR/uv"
APW_PYTHON_DIR="$APW_RUNTIME_DIR/python"
APW_VERSION_DIR="$APW_DATA_DIR/versions/$APP_VERSION"
APW_TEMP_DIR="$(mktemp -d "${TMPDIR:-/tmp}/apw-install.XXXXXX")"
APW_LAUNCHER="$APW_BIN_DIR/apw"
APW_LONG_LAUNCHER="$APW_BIN_DIR/agent-project-workflow"
APW_LAUNCHER_NEW="$APW_BIN_DIR/.apw.new.$$"
CURRENT_NEW="$APW_DATA_DIR/.current.new"
trap 'rm -rf "$APW_TEMP_DIR"; rm -f "$APW_LAUNCHER_NEW" "$CURRENT_NEW"' EXIT HUP INT TERM

if [ "$DRY_RUN" -eq 1 ]; then
  printf '计划安装 Agent Project Workflow %s\n' "$APP_VERSION"
  printf '管理器目录：%s\n' "$APW_DATA_DIR"
  printf '私有 Python：%s\n' "$PYTHON_VERSION"
  printf '私有 uv：%s\n' "$UV_VERSION"
  exit 0
fi

if [ -e "$APW_LAUNCHER" ] || [ -L "$APW_LAUNCHER" ]; then
  [ ! -L "$APW_LAUNCHER" ] || fail "启动器已存在且不是本管理器拥有的普通文件：$APW_LAUNCHER"
  grep -q '^# agent-project-workflow:launcher$' "$APW_LAUNCHER" || \
    fail "启动器路径已被其他程序占用：$APW_LAUNCHER"
fi
if [ -e "$APW_LONG_LAUNCHER" ] || [ -L "$APW_LONG_LAUNCHER" ]; then
  [ -L "$APW_LONG_LAUNCHER" ] || fail "启动器路径已被其他程序占用：$APW_LONG_LAUNCHER"
  [ "$(readlink "$APW_LONG_LAUNCHER")" = "$APW_LAUNCHER" ] || \
    fail "启动器符号链接不属于本管理器：$APW_LONG_LAUNCHER"
fi

mkdir -p "$APW_UV_DIR" "$APW_PYTHON_DIR" "$APW_VERSION_DIR" "$APW_STATE_DIR" "$APW_CACHE_DIR" "$APW_BIN_DIR"

UV_INSTALLER="$APW_TEMP_DIR/uv-installer.sh"
curl --proto '=https' --tlsv1.2 -fsSL \
  "https://releases.astral.sh/github/uv/releases/download/${UV_VERSION}/uv-installer.sh" \
  -o "$UV_INSTALLER"
env UV_UNMANAGED_INSTALL="$APW_UV_DIR" UV_NO_MODIFY_PATH=1 sh "$UV_INSTALLER"

UV_BIN="$APW_UV_DIR/uv"
[ -x "$UV_BIN" ] || fail "私有 uv 安装失败"
env UV_PYTHON_INSTALL_DIR="$APW_PYTHON_DIR" UV_CACHE_DIR="$APW_CACHE_DIR/uv" UV_NO_CONFIG=1 \
  "$UV_BIN" python install "$PYTHON_VERSION" --install-dir "$APW_PYTHON_DIR" --no-bin
PYTHON_BIN="$(env UV_PYTHON_INSTALL_DIR="$APW_PYTHON_DIR" UV_CACHE_DIR="$APW_CACHE_DIR/uv" UV_NO_CONFIG=1 \
  "$UV_BIN" python find --managed-python "$PYTHON_VERSION")"
[ -x "$PYTHON_BIN" ] || fail "私有 Python 安装失败"

APW_PYZ="$APW_VERSION_DIR/apw.pyz"
if [ -n "${APW_PYZ_SOURCE:-}" ]; then
  cp "$APW_PYZ_SOURCE" "$APW_TEMP_DIR/apw.pyz"
else
  curl --proto '=https' --tlsv1.2 -fsSL "$RELEASE_BASE/apw.pyz" -o "$APW_TEMP_DIR/apw.pyz"
fi

if command -v shasum >/dev/null 2>&1; then
  ACTUAL_SHA256="$(shasum -a 256 "$APW_TEMP_DIR/apw.pyz" | awk '{print $1}')"
elif command -v sha256sum >/dev/null 2>&1; then
  ACTUAL_SHA256="$(sha256sum "$APW_TEMP_DIR/apw.pyz" | awk '{print $1}')"
else
  fail "系统缺少 shasum 或 sha256sum，无法验证下载内容"
fi
[ "$ACTUAL_SHA256" = "$APW_SHA256" ] || fail "apw.pyz SHA-256 校验失败"

chmod 755 "$APW_TEMP_DIR/apw.pyz"
mv "$APW_TEMP_DIR/apw.pyz" "$APW_PYZ"

rm -f "$CURRENT_NEW"
ln -s "versions/$APP_VERSION" "$CURRENT_NEW"
"$PYTHON_BIN" -c 'import os, sys; os.replace(sys.argv[1], sys.argv[2])' \
  "$CURRENT_NEW" "$APW_DATA_DIR/current"

{
  printf '#!/bin/sh\n'
  printf '# agent-project-workflow:launcher\n'
  printf 'export UV_PYTHON_INSTALL_DIR=%s\n' "$(shell_quote "$APW_PYTHON_DIR")"
  printf 'export UV_CACHE_DIR=%s\n' "$(shell_quote "$APW_CACHE_DIR/uv")"
  printf 'export UV_NO_CONFIG=1\n'
  printf 'export APW_RUNTIME_PYTHON=%s\n' "$(shell_quote "$PYTHON_BIN")"
  printf 'export APW_RUNTIME_PYTHON_VERSION=%s\n' "$(shell_quote "$PYTHON_VERSION")"
  printf 'export APW_RUNTIME_UV=%s\n' "$(shell_quote "$UV_VERSION")"
  printf 'exec %s %s --home %s "$@"\n' \
    "$(shell_quote "$PYTHON_BIN")" \
    "$(shell_quote "$APW_DATA_DIR/current/apw.pyz")" \
    "$(shell_quote "$APW_USER_HOME")"
} >"$APW_LAUNCHER_NEW"
chmod 755 "$APW_LAUNCHER_NEW"
mv -f "$APW_LAUNCHER_NEW" "$APW_LAUNCHER"
ln -sf "$APW_LAUNCHER" "$APW_LONG_LAUNCHER"

printf '已安装 Agent Project Workflow %s。\n' "$APP_VERSION"
if [ "${APW_BOOTSTRAP_SKIP_WIZARD:-0}" = "1" ]; then
  printf '已跳过交互向导，请运行：%s install\n' "$APW_LAUNCHER"
elif [ -r /dev/tty ] && [ -w /dev/tty ]; then
  "$APW_LAUNCHER" install </dev/tty >/dev/tty
else
  printf '当前不是交互终端，请稍后运行：%s install\n' "$APW_LAUNCHER"
fi
